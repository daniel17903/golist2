{
  "name": "@golist/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/db/cli.ts migrate",
    "db:seed": "tsx src/db/cli.ts seed"
  },
  "dependencies": {
    "fastify": "5.6.1",
    "zod": "4.3.6",
    "pg": "8.18.0"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "@typescript-eslint/eslint-plugin": "8.46.1",
    "@typescript-eslint/parser": "8.46.1",
    "eslint": "9.37.0",
    "globals": "17.3.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "@types/pg": "8.16.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
