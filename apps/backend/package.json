{
  "name": "@golist/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/db/cli.ts migrate",
    "db:seed": "tsx src/db/cli.ts seed"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@golist/shared": "0.1.0",
    "fastify": "5.8.1",
    "pg": "8.20.0",
    "zod": "4.3.6",
    "@fastify/websocket": "11.2.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.1",
    "globals": "17.4.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.0",
    "@types/ws": "8.18.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
